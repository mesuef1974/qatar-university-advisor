{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(node:*)",
      "Bash(git:*)",
      "Read(C:/Users/mesue/.claude/**)",
      "Read(D:/qatar-university-advisor/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🏢 Azkia v4.0 — Session Started' && node C:/Users/mesue/.claude/azkia-company/azkia-cli.js health"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "^/azkia-",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🎯 Azkia v4.0 — Skill invoked'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🧠 Memory: ① CEO لا يكتب كود ② Logic Gate قبل كل قرار ③ QA قبل كل push'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd C:/Users/mesue/.claude/azkia-company && node v3/tools/skill-versioning.js snapshot 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "(Write|Edit).*(src/|lib/|api/)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️ تحذير: CEO لا يكتب كود — تأكد أن القسم الهندسي هو المنفذ'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd C:/Users/mesue/.claude/azkia-company && node v3/tools/backup-system.js backup 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "_azkia_company": {
    "project_id": "qatar-university-advisor",
    "company_path": "C:/Users/mesue/.claude/azkia-company/",
    "version": "4.0"
  }
}
