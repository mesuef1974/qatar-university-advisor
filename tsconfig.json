{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "strictNullChecks": true,

    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "baseUrl": ".",
    "paths": {
      "@lib/*": ["lib/*"],
      "@api/*": ["api/*"],
      "@types/*": ["types/*"]
    }
  },
  "include": [
    "src/**/*",
    "lib/**/*.ts",
    "api/**/*.ts",
    "types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "lib/**/*.js",
    "api/**/*.js"
  ]
}
