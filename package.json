{
  "name": "qatar-university-advisor",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "type-check": "tsc --noEmit",
    "test:perf": "echo 'Install k6 first: https://k6.io/docs/get-started/installation/' && k6 run tests/performance/k6-health.js",
    "test:perf:webhook": "k6 run tests/performance/k6-webhook.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "@upstash/ratelimit": "^2.0.4",
    "@upstash/redis": "^1.31.0",
    "i18next": "^26.0.3",
    "jspdf": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.43.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  }
}
