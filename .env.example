# ══════════════════════════════════════════════════════════════
# Qatar University Advisor — متغيرات البيئة المطلوبة
# ══════════════════════════════════════════════════════════════
# انسخ هذا الملف إلى .env.local للتطوير المحلي:
#   cp .env.example .env.local
#
# في Vercel: أضف هذه المتغيرات من:
#   Dashboard → Project → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────
# 1. WhatsApp Business API
#    المصدر: https://developers.facebook.com/apps
#            → اختر تطبيقك → WhatsApp → API Setup
# ─────────────────────────────────────────────────────────────

# رمز الوصول الدائم (Permanent Access Token)
# اذهب إلى: Meta Business Suite → System Users → Generate Token
# الصلاحيات المطلوبة: whatsapp_business_management, whatsapp_business_messaging
WHATSAPP_TOKEN=your_whatsapp_permanent_access_token

# معرف رقم الهاتف (Phone Number ID) — ليس الرقم نفسه بل ID رقمي
# اذهب إلى: Facebook Developers → تطبيقك → WhatsApp → API Setup
WHATSAPP_PHONE_ID=your_phone_number_id

# رمز التحقق من الـ Webhook (أي نص تختاره — ستستخدمه مرة واحدة عند الربط)
WEBHOOK_VERIFY_TOKEN=your_custom_verify_token_here

# ─────────────────────────────────────────────────────────────
# 2. أمان الـ Webhook — مطلوب لبيئة الإنتاج
#    ⚠️  بدونه سيرفض التطبيق كل طلبات POST في الإنتاج
# ─────────────────────────────────────────────────────────────

# App Secret — مفتاح التحقق من توقيع Meta X-Hub-Signature-256
# كيفية الحصول عليه:
#   1. اذهب إلى: https://developers.facebook.com/apps
#   2. اختر تطبيقك
#   3. من القائمة اليسرى: App Settings → Basic
#   4. انسخ قيمة "App Secret" (اضغط Show إذا كانت مخفية)
WEBHOOK_APP_SECRET=your_facebook_app_secret_from_basic_settings

# ─────────────────────────────────────────────────────────────
# 3. Google Gemini AI — مجاني ومُوصى به
#    النموذج: gemini-1.5-flash (مجاني: 15 طلب/دقيقة، 1M token/يوم)
#    للحصول على مفتاح مجاني: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key


# ─────────────────────────────────────────────────────────────
# 4. Supabase — Server-side only
#    المصدر: https://supabase.com → Project → Settings → API
#
#    ⚠️  SECURITY (DEC-SEC-002 / RLS hotfix 2026-04-10):
#    • Backend writes/reads use SERVICE_ROLE_KEY (يتجاوز RLS).
#    • SERVICE_ROLE_KEY سري — لا تضعه في أي متغير بادئته NEXT_PUBLIC_*
#      لأن Next.js يحقن أي NEXT_PUBLIC_* في الحزمة المرئية للمتصفح.
#    • في Vercel: أضف SUPABASE_SERVICE_ROLE_KEY في Environment Variables
#      (Production + Preview + Development حسب الحاجة)، بدون أي bادئة.
#    • ANON_KEY مهجور للـ backend بعد migration 003.
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Deprecated — do NOT use for backend writes/reads.
# Kept here only for reference; backend switched to SERVICE_ROLE_KEY.
# SUPABASE_ANON_KEY=your_supabase_anon_key


# ─────────────────────────────────────────────────────────────
# 5. Upstash Redis — Rate Limiting (توصى به في الإنتاج)
#    المصدر: https://console.upstash.com → Create Database → REST API
#    يُستخدم لتحديد معدل الطلبات عبر جميع Vercel Functions بدلاً من
#    الـ in-memory map (التي تُفقد عند إعادة تشغيل الـ serverless instance).
#    إذا لم يُضبط، يعمل التطبيق بدون rate limiting موزع (مناسب للتطوير المحلي).
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token


# ─────────────────────────────────────────────────────────────
# 6. لوحة الأدمن — كلمة مرور الوصول السري
#    يُستخدم في App.jsx — النقر 5 مرات على اللوغو يطلب كلمة مرور
#    ⚠️  يجب إضافته في Vercel Dashboard أيضاً (بيئة الإنتاج)
#    بدونه: لوحة الأدمن لن تعمل أبداً
# ─────────────────────────────────────────────────────────────
VITE_ADMIN_UI_PASSWORD=your_strong_admin_password_here


# ══════════════════════════════════════════════════════════════
# ملاحظات أمنية
# ══════════════════════════════════════════════════════════════
# • لا ترفع هذا الملف بعد ملئه إلى Git — أضف .env.local إلى .gitignore
# • في Vercel، استخدم Environment Variables وليس ملفات .env مباشرة
# • جدِّد WHATSAPP_TOKEN قبل انتهاء صلاحيته
# • WEBHOOK_APP_SECRET لا تتغير إلا إذا أعدت توليد App Secret من Meta
# ══════════════════════════════════════════════════════════════
