# Staging Environment Variables
# نسخ من هذا الملف وتسميته .env.staging
# يُستخدم مع Vercel Preview Deployments

# Supabase (Staging DB - منفصلة عن Production)
SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# WhatsApp Business API (Sandbox للاختبار)
WHATSAPP_TOKEN=your-whatsapp-test-token
WHATSAPP_PHONE_ID=your-test-phone-id
WEBHOOK_SECRET=your-staging-webhook-secret

# Admin Panel
ADMIN_PASSWORD=staging-admin-password
ADMIN_ORIGIN=https://your-staging-deployment.vercel.app

# PDPPL Cron
CRON_SECRET=your-staging-cron-secret

# Environment Indicator
NODE_ENV=staging
VITE_ENV=staging
